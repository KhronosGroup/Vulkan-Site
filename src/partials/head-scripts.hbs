    {{#with site.keys.googleTagManager}}
    <!-- 1. Site-specific variables. Set these before the CDN scripts load. -->
    <script>
    var klaroCookieDomain = '.vulkan.org';
    var klaroGtmId = '{{this}}';
    var klaroPrivacyPolicyUrl = 'https://www.khronos.org/legal/privacy';
    </script>

    <!-- 2. Shared CDN assets. Replace cdn.khronos.org with your CDN host and
         always reference a pinned version path. -->
    <link rel="stylesheet" href="https://cdn.khronos.org/cookies/v1/klaro.css">
    <script defer src="https://cdn.khronos.org/cookies/v1/klaro-bundle.min.js"></script>
    <!-- The GTM loader runs on every page view (Google Consent Mode advanced):
         it reads the saved Klaro consent cookie and starts GTM with the matching
         granted/denied consent default. Keep it after the Klaro bundle so the GPC
         opt-out cookie is written before the loader reads it. -->
    <script defer src="https://cdn.khronos.org/cookies/v1/gtm-loader.js"></script>
    {{/with}}
    {{!--
    <script>var uiRootPath = '{{{uiRootPath}}}'</script>
    --}}
