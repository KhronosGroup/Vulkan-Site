    {{#with site.keys.google_analytics}}
    <!-- 1. Site-specific variables. Set these before the CDN scripts load. -->
    <script>
    var klaroCookieDomain = '.vulkan.org';
    var klaroGtmId = '{{this}}';
    var klaroPrivacyPolicyUrl = 'https://www.khronos.org/legal/privacy';
    </script>

    <!-- 2. Shared CDN assets. Replace cdn.khronos.org with your CDN host and
         always reference a pinned version path. -->
    <link rel="stylesheet" href="https://cdn.khronos.org/cookies/v1/klaro.css">
    <script defer type="text/javascript" src="https://cdn.khronos.org/cookies/v1/klaro-bundle.min.js"></script>
    <script data-type="application/javascript" type="text/plain" data-name="google-tag-manager"
            src="https://cdn.khronos.org/cookies/v1/gtm-loader.js"></script>
    {{/with}}
