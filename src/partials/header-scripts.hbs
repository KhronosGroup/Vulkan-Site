{{#with site.keys.googleTagManager}}
<!-- 3. GTM noscript fallback. The container ID must be hardcoded here because
     noscript content cannot read JS variables. Keep it in sync with klaroGtmId. -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id={{this}}"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
{{/with}}
